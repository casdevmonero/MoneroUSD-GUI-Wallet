{
  "name": "monerousd-desktop",
  "version": "1.2.27",
  "description": "Monero USD desktop wallet - balance, send, receive, swap",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "browser": "node server.js",
    "build": "electron-builder --linux --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --linux --win --mac",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "homepage": "https://monerousd.org",
  "author": {
    "name": "Monero USD",
    "email": "support@monerousd.org"
  },
  "license": "MIT",
  "dependencies": {
    "@simplewebauthn/server": "^11.0.0",
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "org.monerousd.desktop",
    "productName": "Monero USD Wallet",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "assets/**"
    ],
    "publish": [
      {
        "provider": "generic",
        "url": "https://update.monerousd.org",
        "channel": "latest"
      }
    ],
    "mac": {
      "category": "public.app-category.finance",
      "icon": "assets/icon.icns",
      "darkModeSupport": true,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Finance"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
